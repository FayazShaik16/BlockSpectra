# BlockSpectra Environment Configuration Template
# Copy this file to .env and fill in the values

# AI Provider Settings
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash

# Database Configuration (falls back to local SQLite if left commented/blank)
# For Render PostgreSQL: postgresql+asyncpg://<user>:<password>@<host>/<database>
# DATABASE_URL=

# Etherscan/BscScan Explorer API Keys for Contract Telemetry
ETHERSCAN_API_KEY=your_etherscan_key_here
ARBISCAN_API_KEY=your_arbiscan_key_here
OP_ETHERSCAN_API_KEY=your_optimism_etherscan_key_here
POLYGONSCAN_API_KEY=your_polygonscan_key_here
BSCSCAN_API_KEY=your_bscscan_key_here
SNOWTRACE_API_KEY=your_avalanche_etherscan_key_here

# Solana RPC Configuration
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
